{
  "rewrites": [
    { "source": "/app",          "destination": "/app.html"     },
    { "source": "/app.html",     "destination": "/app.html"     },
    { "source": "/privacy.html", "destination": "/privacy.html" },
    { "source": "/terms.html",   "destination": "/terms.html"   },
    { "source": "/refund.html",  "destination": "/refund.html"  },
    { "source": "/privacy",      "destination": "/privacy.html" },
    { "source": "/terms",        "destination": "/terms.html"   },
    { "source": "/refund",       "destination": "/refund.html"  },
    { "source": "/sitemap.xml",  "destination": "/sitemap.xml"  },
    { "source": "/robots.txt",   "destination": "/robots.txt"   }
  ],
  "functions": {
    "api/ask.js": {
      "maxDuration": 30
    },
    "api/create-checkout-session.js": {
      "maxDuration": 15
    },
    "api/customer-portal.js": {
      "maxDuration": 15
    },
    "api/webhook.js": {
      "maxDuration": 15
    },
    "api/send-welcome-email.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "https://www.knoxknowsapp.com" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
